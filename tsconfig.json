{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "types": ["node"],
        /* Môi trường và Target */
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",

        /* Output */
        "outDir": "./dist",
        "sourceMap": false,
        "esModuleInterop": true,

        /* Strictness */
        "strict": true,
        "skipLibCheck": true,

        /* Module & Alias */
        "paths": {
            "@/*": ["./src/*"],
            "@test/*": ["./test/*"],
            "@src/*": ["./src/*"],
            "@langs/*": ["./src/langs/*"],
            "@modules/*": ["./src/modules/*"],
            "@module-base/*": ["./src/modules/module-base/*"],
            "@module-user/*": ["./src/modules/module-user/*"],
            "@module-auth/*": ["./src/modules/module-auth/*"],
            "@module-global/*": ["./src/modules/module-global/*"],
            "@module-messenger/*": ["./src/modules/module-messenger/*"]
        },

        /* Type Declaration */
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,

        /* Tiện ích */
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "removeComments": true,
        "allowJs": false,
        "allowSyntheticDefaultImports": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": ["src/**/*", "test/**/*"],
    "exclude": ["node_modules", "dist"]
}
